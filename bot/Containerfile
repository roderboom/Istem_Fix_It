# ── FixBot — Python Telegram Bot ─────────────────────────────────────────────
FROM python:3.12-slim

LABEL org.opencontainers.image.title="FixBot"
LABEL org.opencontainers.image.description="Telegram repair assistant powered by local vision AI"

WORKDIR /app

# System deps for Pillow (font rendering, JPEG support)
RUN apt-get update && apt-get install -y --no-install-recommends \
    libfreetype6-dev \
    libjpeg-dev \
    libpng-dev \
    zlib1g-dev \
    fonts-dejavu-core \
    fonts-liberation \
    fonts-noto \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy source code
COPY . .

# Non-root user for security
RUN useradd --create-home --shell /bin/bash fixbot
USER fixbot

CMD ["python", "-u", "bot.py"]
