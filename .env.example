# ── FixBot Environment Variables ─────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#   nano .env

# ── Required ──────────────────────────────────────────────────────────────────

# Your Telegram bot token — get it from @BotFather on Telegram
TELEGRAM_TOKEN=7123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Access Control ────────────────────────────────────────────────────────────

# Your Telegram user ID — get it by sending /start to @userinfobot
# The admin can approve/deny new users and use /adduser /removeuser /listusers
ADMIN_USER_ID=123456789

# Optional: comma-separated user IDs to pre-approve at startup
# Leave empty to start with only the admin allowed
ALLOWED_USERS=123456789,987654321

# ── Model Settings ────────────────────────────────────────────────────────────

# Vision model to use. Recommended options for 16GB VRAM:
#   gemma4:26b   — best quality, ~18GB, ~40s per request  (recommended)
#   gemma4:e4b   — fast, ~10GB,
#   qwen2.5vl:7b — fast, ~5GB,
MODEL_NAME=gemma4:26b

# ── Ollama Connection ─────────────────────────────────────────────────────────

# Leave as-is when using compose.yaml — only change if running Ollama manually
OLLAMA_HOST=http://ollama:11434

# ── Storage ───────────────────────────────────────────────────────────────────

# Where repair history and whitelist are stored inside the container
# Leave as-is unless you change the volume mount in compose.yaml
HISTORY_DIR=/data/history
